# Copy to .env and adjust for your environment.

# Path to the SQLite database file
NANOBROKER_DB_FILE=broker_local.db

# Bind address (0.0.0.0 exposes to the whole LAN)
NANOBROKER_HOST=0.0.0.0

# HTTP port
NANOBROKER_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
NANOBROKER_LOG_LEVEL=INFO

# SQLite busy timeout in seconds
NANOBROKER_DB_TIMEOUT=5
